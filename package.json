{
  "name": "lzma-web",
  "maintainers": [
    "Ben Williams <git@biwills.com>"
  ],
  "author": "Nathan Rugg <nmrugg@gmail.com>",
  "description": "A JavaScript implementation of the Lempel-Ziv-Markov (LZMA) chain compression algorithm",
  "version": "3.0.1",
  "homepage": "https://github.com/biw/lzma-web",
  "repository": {
    "type": "git",
    "url": "git://github.com/biw/lzma-web.git"
  },
  "bugs": {
    "url": "https://github.com/biw/lzma-web/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/node": "22.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "eslint": "9.38.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "tsup": "8.5.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.2",
    "vite": "6.2.1",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:perf": "node scripts/track-perf.js",
    "test:bench": "vitest bench",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "type-check": "tsc --noEmit",
    "prepack": "yarn build"
  },
  "license": "MIT",
  "keywords": [
    "lzma",
    "compression",
    "decompression"
  ],
  "packageManager": "yarn@4.10.3"
}
